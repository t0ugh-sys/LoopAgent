{
  "name": "@t0ugh-sys/anvil",
  "version": "0.1.0",
  "description": "Node CLI wrapper for the Anvil Python runtime",
  "main": "bin/loopagent.js",
  "bin": {
    "anvil": "bin/loopagent.js",
    "loopagent": "bin/loopagent.js"
  },
  "type": "commonjs",
  "files": [
    "bin",
    "src/**/*.py",
    "src/**/py.typed",
    "pyproject.toml",
    "README.md",
    "LICENSE",
    "requirements.txt"
  ],
  "scripts": {
    "test": "python -m unittest discover -s tests -p \"test_*.py\" -v",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run pack:check"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "agent",
    "cli",
    "llm",
    "python",
    "node",
    "automation"
  ],
  "homepage": "https://github.com/t0ugh-sys/LoopAgent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0ugh-sys/LoopAgent.git"
  },
  "bugs": {
    "url": "https://github.com/t0ugh-sys/LoopAgent/issues"
  }
}
