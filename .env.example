# LoopAgent Configuration
#
# Copy this file to .env and fill in your values
# Or use --config flag to specify config file

# Provider settings
LOOPAGENT_PROVIDER=mock
LOOPAGENT_MODEL=mock-model

# OpenAI settings (if using openai_compatible provider)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic settings (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini settings (if using gemini provider)
# GEMINI_API_KEY=your-gemini-key

# Agent settings
LOOPAGENT_MAX_STEPS=20
LOOPAGENT_TIMEOUT_S=60
LOOPAGENT_TEMPERATURE=0.2
LOOPAGENT_HISTORY_WINDOW=3

# Memory settings
# LOOPAGENT_MEMORY_DIR=.loopagent/runs

# Skills to load (comma-separated)
# LOOPAGENT_SKILLS=web_search,memory,files,commands

# Advanced settings
# LOOPAGENT_PROVIDER_TIMEOUT_S=60
# LOOPAGENT_MAX_RETRIES=2
# LOOPAGENT_RETRY_BACKOFF_S=1.0
